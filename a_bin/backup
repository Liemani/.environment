if [[ $# -ge 2 ]]; then
	echo 'usage: a backup [<message>]'
	return 1
fi

if [[ $# -eq 0 ]]; then
	1="backup"
fi

repositories=($(find $git -depth 1 -type d))
for repository in $repositories; do
	cd $repository
	a push "$1"
done

unset repositories
unset repository
